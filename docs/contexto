## 6. Modelagem de Dados

### 6.1 Tipos Principais (TypeScript)

```typescript
type FoodCategory = 'carboidrato' | 'salada' | 'proteina';

interface FoodItem {
  id: string;
  name: string;
  category: FoodCategory;
  caloriesPer100g: number;
  defaultPortionGrams: number;
  unit: 'g' | 'ml' | 'unidade';
}

interface SelectedPortion {
  food: FoodItem;
  portionGrams: number;
  totalCalories: number;
}

interface Cardapio {
  id: string;
  date: string;
  portions: SelectedPortion[];
  totalCalories: number;
  isValid: boolean;
}

interface ProducaoConfig {
  platesToProduce: number;
  surplusPercent: number;       // 0.00 a 0.40
  totalPlates: number;          // calculado
  ingredientsList: IngredientRequirement[];
}

interface IngredientRequirement {
  food: FoodItem;
  totalGrams: number;
  totalCalories: number;
}
```

