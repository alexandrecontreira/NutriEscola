<!-- ============================================================
   DASHBOARD HOME - resumo operacional do NutriEscola
   Data keys: dashboard.*, menu_preview.*, production_preview.*
   ============================================================ -->
<section id="dashboard" class="layout_padding">
  <div class="container">
    <div class="section-title text-center">
      <span class="section-eyebrow">{{dashboard.eyebrow}}</span>
      <h2>{{dashboard.title}}</h2>
      <p>{{dashboard.subtitle}}</p>
    </div>

    <div class="row g-4">
      {{#dashboard.cards}}
      <div class="col-md-6 col-lg-3">
        <article class="summary-card">
          <div class="summary-icon">
            <i class="fa {{icon}}" aria-hidden="true"></i>
          </div>
          <div class="summary-value">{{value}}</div>
          <div class="summary-label">{{label}}</div>
        </article>
      </div>
      {{/dashboard.cards}}
    </div>
  </div>
</section>

<section id="cardapio-resumo" class="menu_section layout_padding">
  <div class="container">
    <div class="section-title d-flex flex-column flex-lg-row align-items-lg-end justify-content-between gap-3">
      <div>
        <span class="section-eyebrow">{{menu_preview.eyebrow}}</span>
        <h2>{{menu_preview.title}}</h2>
        <p>{{menu_preview.subtitle}}</p>
      </div>
      <a href="cardapio.html" class="btn-nutri">Montar cardapio</a>
    </div>

    <div class="row g-4">
      {{#menu_preview.items}}
      <div class="col-md-6 col-lg-4">
        <article class="food-card">
          <div class="food-img-box">
            <img src="{{image}}" alt="{{name}}" loading="lazy">
          </div>
          <div class="food-detail-box">
            <span class="food-category">{{category_label}}</span>
            <h3 class="h5 mt-3 mb-2">{{name}}</h3>
            <p class="text-muted mb-3">{{portion}} por prato - {{calories}} kcal</p>
            <div class="d-flex justify-content-between small text-muted">
              <span>{{calories_per_100g}} kcal/100g</span>
              <span>{{status}}</span>
            </div>
          </div>
        </article>
      </div>
      {{/menu_preview.items}}
    </div>
  </div>
</section>

<section class="dark-section layout_padding2">
  <div class="container">
    <div class="row align-items-center g-4">
      <div class="col-lg-6">
        <div class="section-title mb-0">
          <span class="section-eyebrow">{{production_preview.eyebrow}}</span>
          <h2>{{production_preview.title}}</h2>
          <p>{{production_preview.subtitle}}</p>
        </div>
      </div>
      <div class="col-lg-6">
        <div class="row g-3">
          {{#production_preview.metrics}}
          <div class="col-sm-4">
            <div class="panel-card text-center">
              <div class="summary-value">{{value}}</div>
              <div class="summary-label">{{label}}</div>
            </div>
          </div>
          {{/production_preview.metrics}}
        </div>
      </div>
    </div>
  </div>
</section>
