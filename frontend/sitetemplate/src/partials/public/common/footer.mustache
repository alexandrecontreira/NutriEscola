<!-- ============================================================
   FOOTER - contato, navegacao e horarios operacionais
   Data keys: site.*, footer.*
   ============================================================ -->
<footer class="footer_section">
  <div class="container">
    <div class="row">
      <div class="col-md-4 footer-col mb-4 mb-md-0">
        <h4>Contato</h4>
        <div class="d-grid gap-2">
          <a href="mailto:{{site.email}}">
            <i class="fa fa-envelope me-2" aria-hidden="true"></i>{{site.email}}
          </a>
          <a href="tel:{{site.phone}}">
            <i class="fa fa-phone me-2" aria-hidden="true"></i>{{site.phone}}
          </a>
          <span>
            <i class="fa fa-map-marker me-2" aria-hidden="true"></i>{{site.address}}
          </span>
        </div>
      </div>

      <div class="col-md-4 footer-col text-md-center mb-4 mb-md-0">
        <a href="index.html" class="footer-logo">{{site.company_name}}</a>
        <p class="mt-3">{{footer.description}}</p>
        <div class="footer_social">
          {{#site.social}}
          <a href="{{url}}" target="_blank" rel="noopener noreferrer" aria-label="{{label}}">
            <i class="fa {{icon}}" aria-hidden="true"></i>
          </a>
          {{/site.social}}
        </div>
      </div>

      <div class="col-md-4 footer-col text-md-end">
        <h4>{{footer.operation.title}}</h4>
        {{#footer.operation.items}}
        <p class="mb-1">{{.}}</p>
        {{/footer.operation.items}}
      </div>
    </div>

    <div class="footer-info">
      <p class="mb-0">
        &copy; <span data-current-year></span> {{site.company_name}}. {{footer.copyright}}
      </p>
    </div>
  </div>
</footer>
