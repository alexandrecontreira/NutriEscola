<!-- ============================================================
   PAGE HERO
   Data keys: page.breadcrumb.*, page.hero.*
   ============================================================ -->
<section class="page_hero">
  <div class="container">
    <nav class="breadcrumb_nutri" aria-label="Breadcrumb">
      <a href="{{page.breadcrumb.home.url}}">{{page.breadcrumb.home.label}}</a>
      <span>/</span>
      <span>{{page.breadcrumb.current}}</span>
    </nav>
    <p class="section-eyebrow mb-2">{{page.hero.eyebrow}}</p>
    <h1 class="hero-title mb-3">{{page.hero.title}}</h1>
    <p class="hero-copy mb-0">{{page.hero.subtitle}}</p>
  </div>
</section>
