<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
  <meta name="description" content="{{site.description}}" />
  <meta name="theme-color" content="#17202a" />
  <meta property="og:title" content="{{site.company_name}} - {{site.tagline}}" />
  <meta property="og:description" content="{{site.description}}" />
  <meta property="og:type" content="website" />
  <title>{{site.company_name}} - {{site.tagline}}</title>
  <link rel="stylesheet" href="css/bootstrap/bootstrap.min.css" />
  <link rel="stylesheet" href="css/fontawesome/all.min.css" />
  <link rel="stylesheet" href="assets/css/main.css" />
</head>
<body data-calorie-limit="{{calorie_summary.limit}}">
  <div class="hero_area">
    <div class="bg-box">
      <img src="assets/images/hero-bg.jpg" alt="Refeicao escolar organizada" loading="eager">
    </div>
    {{> partials/public/common/header}}

    <section class="slider_section">
      <div class="container">
        <div class="row align-items-center">
          <div class="col-lg-7">
            <p class="section-eyebrow">{{hero.eyebrow}}</p>
            <h1 class="hero-title">{{hero.title}}</h1>
            <p class="hero-copy">{{hero.subtitle}}</p>
            <div class="d-flex flex-wrap gap-3 mt-4">
              <a href="{{hero.cta_primary.url}}" class="btn-nutri">{{hero.cta_primary.label}}</a>
              <a href="{{hero.cta_secondary.url}}" class="btn-outline-nutri">{{hero.cta_secondary.label}}</a>
            </div>
          </div>
          <div class="col-lg-5">
            <aside class="hero-panel" aria-label="Resumo do cardapio">
              <img src="assets/images/about-img.png" alt="Prato escolar balanceado" loading="eager">
              {{#hero.stats}}
              <div class="hero-stat">
                <span>{{label}}</span>
                <strong>{{value}}</strong>
              </div>
              {{/hero.stats}}
            </aside>
          </div>
        </div>
      </div>
    </section>
  </div>

  <main id="main">
    {{> dashboard}}
  </main>

  {{> partials/public/common/footer}}
  <script src="js/bootstrap/bootstrap.min.js"></script>
  <script src="assets/js/main.js"></script>
</body>
</html>
