<!DOCTYPE html>
<html lang="pt-BR" class="scroll-smooth">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Entre em contato com a {{site.company_name}}. Estamos prontos para entender seu desafio e construir a solução certa para o seu negócio." />
  <meta name="theme-color" content="#0a0a0a" />

  <!-- Open Graph -->
  <meta property="og:title"       content="Contato — {{site.company_name}}" />
  <meta property="og:description" content="Entre em contato com a {{site.company_name}}. Estamos prontos para entender seu desafio e construir a solução certa para o seu negócio." />
  <meta property="og:type"        content="website" />

  <title>Contato — {{site.company_name}}</title>

  <!-- Preconnect for Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap"
        rel="stylesheet" />

  <!-- Tailwind CSS (CDN — replace with compiled bundle in production) -->
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'system-ui', 'sans-serif'],
            mono: ['"JetBrains Mono"', '"Courier New"', 'monospace'],
          },
        },
      },
    };
  </script>

  <!-- Custom CSS -->
  <link rel="stylesheet" href="assets/css/main.css" />

  <!-- Lucide Icons (lightweight SVG icon library) -->
  <script src="https://unpkg.com/lucide@latest/dist/umd/lucide.min.js" defer></script>
</head>

<body class="font-sans text-slate-800 bg-white antialiased">

  <!-- ──────────────────────────────────────────────
       TOPBAR  (email · phone · social)
       ────────────────────────────────────────────── -->
  {{> partials/public/common/topbar}}

  <!-- ──────────────────────────────────────────────
       HEADER  (logo · nav · CTA)
       ────────────────────────────────────────────── -->
  {{> partials/public/common/header}}

  <!-- ──────────────────────────────────────────────
       MAIN CONTENT
       ────────────────────────────────────────────── -->
  <main id="main">

    <!-- PAGE HERO (dark) — breadcrumb + title -->
    <section class="pt-32 pb-16 bg-[#0a0a0a] relative overflow-hidden">
      <!-- Background grid decoration -->
      <div class="absolute inset-0 opacity-5"
           style="background-image: linear-gradient(#16a34a 1px, transparent 1px), linear-gradient(90deg, #16a34a 1px, transparent 1px); background-size: 40px 40px;">
      </div>
      <div class="container mx-auto px-4 md:px-8 lg:px-12 relative">

        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 text-sm font-mono mb-6" aria-label="Breadcrumb">
          <a href="index.html" class="text-slate-500 hover:text-green-400 transition-colors duration-200">Início</a>
          <i data-lucide="chevron-right" class="w-3 h-3 text-slate-600"></i>
          <span class="text-green-400">Contato</span>
        </nav>

        <div class="inline-flex items-center gap-2 text-green-400 text-sm font-mono font-medium mb-4 tracking-wider">
          <span class="text-green-500">>://</span>
          <span>Fale conosco</span>
        </div>
        <h1 class="text-4xl lg:text-5xl font-bold text-white mb-4">
          Vamos construir algo<br class="hidden sm:block" /> juntos?
        </h1>
        <p class="text-slate-400 text-lg max-w-xl leading-relaxed">
          Conta pra gente seu desafio. A primeira conversa é gratuita e sem compromisso — a ideia é entender se faz sentido trabalharmos juntos.
        </p>
      </div>
    </section>

    {{> partials/pages/contact_full }}



  </main>

  <!-- ──────────────────────────────────────────────
       FOOTER  (links + bottom bar — sem seção de contato)
       ────────────────────────────────────────────── -->
  {{> partials/public/common/footer}}

  <!-- ──────────────────────────────────────────────
       SCRIPTS
       ────────────────────────────────────────────── -->
  <script src="assets/js/main.js"></script>

</body>
</html>