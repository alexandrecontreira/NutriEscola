<!-- ══════════════════════════════════════════════════════════════════════════
     PORTFOLIO FULL PAGE CONTENT
     ══════════════════════════════════════════════════════════════════════════ -->

<!-- CATEGORY FILTER -->
<section class="bg-white py-6 shadow-sm sticky top-0 z-30 border-b border-slate-100">
    <div class="container mx-auto px-4 md:px-8 lg:px-12">
        <div class="flex flex-wrap gap-2 items-center">
            {{#portfolio_page.categories}}
                <button
                    data-filter="{{id}}"
                    class="px-4 py-2 rounded-full text-sm font-medium font-mono transition-all duration-200
                        {{#active}}bg-green-600 text-white shadow-sm active-filter{{/active}}
                        {{^active}}bg-slate-100 text-slate-600 hover:bg-slate-200{{/active}}">
                    {{label}}
                </button>
            {{/portfolio_page.categories}}
        </div>
    </div>
</section>

<!-- PORTFOLIO GRID -->
<section class="bg-slate-950 py-16 lg:py-20">
    <div class="container mx-auto px-4 md:px-8 lg:px-12">

        <!-- Section header -->
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-10">
            <div>
                <div class="inline-flex items-center gap-2 text-green-400 text-sm font-mono font-medium mb-3 tracking-wider">
                    <span class="text-green-500">>://</span>
                    <span>{{portfolio_page.eyebrow}}</span>
                </div>
                <h2 class="text-3xl md:text-4xl font-bold text-white">
                    {{portfolio_page.title}}
                </h2>
            </div>
            <p class="text-slate-500 text-sm font-mono md:text-right leading-relaxed max-w-sm">
                {{portfolio_page.subtitle}}
            </p>
        </div>

        <!-- Grid -->
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 lg:gap-5" id="portfolio-grid">
            {{#portfolio_page.items}}
                <div data-category="{{category_id}}"
                     class="group relative overflow-hidden rounded-xl bg-slate-900 border border-slate-800
                            {{#featured}}sm:col-span-2 lg:col-span-1{{/featured}}
                            hover:border-green-700/50 transition-all duration-300 cursor-pointer">

                    <!-- Cover image -->
                    <a href="{{url}}" class="block relative overflow-hidden">
                        <div class="aspect-[4/3] overflow-hidden bg-slate-800">
                            <img src="{{cover}}"
                                 alt="{{client}} — {{title}}"
                                 class="w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-105"
                                 loading="lazy"
                                 onerror="this.closest('.aspect-\\[4\\/3\\]').classList.add('flex','items-center','justify-center'); this.style.display='none'; this.insertAdjacentHTML('afterend', '<i data-lucide=\'image\' class=\'w-12 h-12 text-slate-600\'></i>');" />
                        </div>

                        <!-- Hover overlay -->
                        <div class="absolute inset-0 bg-gradient-to-t from-slate-950 via-slate-950/70 to-transparent
                                    opacity-0 group-hover:opacity-100 transition-opacity duration-300
                                    flex flex-col justify-end p-5">
                            <p class="text-slate-300 text-sm leading-relaxed mb-3 line-clamp-2">
                                {{description}}
                            </p>
                            <span class="inline-flex items-center gap-1.5 text-green-400 text-sm font-semibold font-mono">
                                Ver projeto
                                <i data-lucide="arrow-right" class="w-4 h-4 group-hover:translate-x-1 transition-transform duration-200"></i>
                            </span>
                        </div>
                    </a>

                    <!-- Card footer -->
                    <div class="p-4 flex items-start justify-between gap-3">
                        <div class="min-w-0">
                            <p class="text-xs font-mono text-slate-500 mb-0.5 truncate">{{client}}</p>
                            <h3 class="text-sm font-semibold text-white leading-snug truncate">{{title}}</h3>
                        </div>
                        <div class="flex flex-col items-end gap-1.5 flex-shrink-0">
                            <span class="text-xs font-mono text-slate-500 bg-slate-800 px-2 py-0.5 rounded whitespace-nowrap">
                                {{category_label}}
                            </span>
                            {{#featured}}
                                <span class="inline-flex items-center gap-1 text-green-400 text-xs font-mono">
                                    <i data-lucide="star" class="w-3 h-3 fill-current"></i>
                                    Destaque
                                </span>
                            {{/featured}}
                        </div>
                    </div>
                </div>
            {{/portfolio_page.items}}
        </div>

    </div>
</section>

<!-- CTA SECTION -->
<section class="bg-green-600 py-16">
    <div class="container mx-auto px-4 md:px-8 lg:px-12">
        <div class="max-w-3xl mx-auto text-center">
            <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
                {{portfolio_page.cta_section.title}}
            </h2>
            <p class="text-green-50 text-lg mb-8 max-w-xl mx-auto leading-relaxed">
                {{portfolio_page.cta_section.subtitle}}
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="contact.html"
                   class="inline-block bg-white text-green-600 font-semibold px-8 py-3 rounded-lg hover:bg-green-50 transition-colors shadow-lg">
                    Falar com a gente
                </a>
                <a href="services.html"
                   class="inline-block bg-green-700 text-white font-semibold px-8 py-3 rounded-lg hover:bg-green-800 transition-colors">
                    Ver serviços
                </a>
            </div>
        </div>
    </div>
</section>

<!-- CATEGORY FILTER SCRIPT -->
<script>
    document.querySelectorAll('[data-filter]').forEach(btn => {
        btn.addEventListener('click', () => {
            const cat = btn.dataset.filter;

            // Update button states
            document.querySelectorAll('[data-filter]').forEach(b => {
                b.classList.remove('active-filter', 'bg-green-600', 'text-white', 'shadow-sm');
                b.classList.add('bg-slate-100', 'text-slate-600');
            });
            btn.classList.add('active-filter', 'bg-green-600', 'text-white', 'shadow-sm');
            btn.classList.remove('bg-slate-100', 'text-slate-600');

            // Filter cards
            document.querySelectorAll('[data-category]').forEach(card => {
                const show = cat === 'all' || card.dataset.category === cat;
                card.style.display = show ? '' : 'none';
            });

            // Re-init Lucide icons (in case they appear in hidden cards)
            if (typeof lucide !== 'undefined') lucide.createIcons();
        });
    });
</script>
