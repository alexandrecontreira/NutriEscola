<!-- ══════════════════════════════════════════════════════════════════════════
     SERVICE DETAIL FULL PAGE CONTENT
     ══════════════════════════════════════════════════════════════════════════ -->

<!-- SERVICE HEADER INFO -->
<section class="bg-white py-12">
    <div class="container mx-auto px-4 md:px-8 lg:px-12">
        <div class="max-w-4xl mx-auto">

            <!-- Back link -->
            <a href="services.html"
               class="inline-flex items-center gap-2 text-slate-500 hover:text-green-600 text-sm font-mono transition-colors mb-8 group">
                <i data-lucide="arrow-left" class="w-4 h-4 group-hover:-translate-x-1 transition-transform"></i>
                Voltar para Serviços
            </a>

            <!-- Tags + featured badge -->
            <div class="flex flex-wrap items-center gap-2 mb-6">
                {{#service.tags}}
                    <span class="text-xs font-mono text-green-700 bg-green-50 border border-green-200 px-3 py-1 rounded-full">
                        {{.}}
                    </span>
                {{/service.tags}}
                {{#service.featured}}
                    <span class="inline-flex items-center gap-1 bg-slate-900 text-white text-xs font-mono font-semibold px-3 py-1 rounded-full">
                        <i data-lucide="star" class="w-3 h-3 text-yellow-400"></i>
                        Serviço em Destaque
                    </span>
                {{/service.featured}}
            </div>

            <!-- Summary -->
            <p class="text-xl text-slate-700 leading-relaxed max-w-3xl">
                {{service.summary}}
            </p>
        </div>
    </div>
</section>

<!-- SERVICES OFFERED -->
<section class="bg-slate-50 py-16">
    <div class="container mx-auto px-4 md:px-8 lg:px-12">
        <div class="max-w-5xl mx-auto">

            <!-- Eyebrow + heading -->
            <div class="text-center mb-12">
                <div class="inline-flex items-center gap-2 text-green-600 text-sm font-mono font-medium mb-3 tracking-wider">
                    <span class="text-green-500">>://</span>
                    <span>O que está incluído</span>
                </div>
                <h2 class="text-3xl md:text-4xl font-bold text-slate-900">
                    Escopo do serviço
                </h2>
            </div>

            <!-- Grid -->
            <div class="grid md:grid-cols-2 gap-6">
                {{#service.services_offered}}
                    <div class="bg-white rounded-lg border border-slate-200 p-6 hover:shadow-sm transition-shadow">
                        <h3 class="text-lg font-semibold text-slate-900 mb-4 flex items-center gap-2">
                            <span class="w-6 h-6 bg-green-600 rounded flex items-center justify-center flex-shrink-0">
                                <i data-lucide="check" class="w-3.5 h-3.5 text-white"></i>
                            </span>
                            {{title}}
                        </h3>
                        <ul class="space-y-2">
                            {{#items}}
                                <li class="flex items-start gap-2 text-sm text-slate-600">
                                    <i data-lucide="check-circle" class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5"></i>
                                    <span>{{.}}</span>
                                </li>
                            {{/items}}
                        </ul>
                    </div>
                {{/service.services_offered}}
            </div>
        </div>
    </div>
</section>

<!-- TECHNOLOGIES -->
<section class="bg-white py-16">
    <div class="container mx-auto px-4 md:px-8 lg:px-12">
        <div class="max-w-5xl mx-auto">

            <!-- Eyebrow + heading -->
            <div class="text-center mb-12">
                <div class="inline-flex items-center gap-2 text-green-600 text-sm font-mono font-medium mb-3 tracking-wider">
                    <span class="text-green-500">>://</span>
                    <span>Stack Tecnológico</span>
                </div>
                <h2 class="text-3xl md:text-4xl font-bold text-slate-900">
                    Tecnologias utilizadas
                </h2>
            </div>

            <!-- Tech provider cards -->
            <div class="grid md:grid-cols-3 gap-6">
                {{#service.technologies}}
                    <div class="bg-slate-50 rounded-lg border border-slate-200 p-6">
                        <h3 class="text-sm font-mono font-semibold text-slate-500 uppercase tracking-widest mb-4">
                            {{provider}}
                        </h3>
                        <div class="flex flex-wrap gap-2">
                            {{#items}}
                                <span class="text-xs font-mono text-slate-700 bg-white border border-slate-300 px-2.5 py-1 rounded">
                                    {{.}}
                                </span>
                            {{/items}}
                        </div>
                    </div>
                {{/service.technologies}}
            </div>
        </div>
    </div>
</section>

<!-- METHODOLOGY -->
<section class="bg-[#0a0a0a] py-16">
    <div class="container mx-auto px-4 md:px-8 lg:px-12">
        <div class="max-w-5xl mx-auto">

            <!-- Eyebrow + heading -->
            <div class="text-center mb-12">
                <div class="inline-flex items-center gap-2 text-green-400 text-sm font-mono font-medium mb-3 tracking-wider">
                    <span class="text-green-500">>://</span>
                    <span>Como trabalhamos</span>
                </div>
                <h2 class="text-3xl md:text-4xl font-bold text-white">
                    Nossa metodologia
                </h2>
                <p class="text-slate-400 mt-4 max-w-2xl mx-auto">
                    Um processo estruturado que garante previsibilidade, qualidade e entregas que realmente fazem sentido para o seu negócio.
                </p>
            </div>

            <!-- Steps -->
            <div class="grid md:grid-cols-5 gap-4">
                {{#service.methodology}}
                    <div class="relative flex flex-col items-center text-center md:items-start md:text-left">
                        <!-- Step number -->
                        <div class="w-12 h-12 rounded-full border-2 border-green-500 flex items-center justify-center mb-4 flex-shrink-0">
                            <span class="text-green-400 font-mono font-bold text-sm">{{step}}</span>
                        </div>
                        <h3 class="text-base font-semibold text-white mb-2">{{title}}</h3>
                        <p class="text-sm text-slate-400 leading-relaxed">{{description}}</p>
                    </div>
                {{/service.methodology}}
            </div>
        </div>
    </div>
</section>

<!-- BENEFITS -->
<section class="bg-slate-50 py-16">
    <div class="container mx-auto px-4 md:px-8 lg:px-12">
        <div class="max-w-4xl mx-auto">

            <!-- Eyebrow + heading -->
            <div class="text-center mb-12">
                <div class="inline-flex items-center gap-2 text-green-600 text-sm font-mono font-medium mb-3 tracking-wider">
                    <span class="text-green-500">>://</span>
                    <span>Por que escolher</span>
                </div>
                <h2 class="text-3xl md:text-4xl font-bold text-slate-900">
                    O que você ganha
                </h2>
            </div>

            <!-- Benefits grid -->
            <div class="grid md:grid-cols-2 gap-4">
                {{#service.benefits}}
                    <div class="flex items-start gap-3 bg-white rounded-lg border border-slate-200 p-5">
                        <div class="w-8 h-8 bg-green-50 rounded-lg flex items-center justify-center flex-shrink-0">
                            <i data-lucide="check-circle-2" class="w-5 h-5 text-green-600"></i>
                        </div>
                        <p class="text-slate-700 leading-relaxed text-sm">{{.}}</p>
                    </div>
                {{/service.benefits}}
            </div>
        </div>
    </div>
</section>

<!-- RELATED SERVICES -->
<section class="bg-white py-12">
    <div class="container mx-auto px-4 md:px-8 lg:px-12">
        <div class="max-w-5xl mx-auto">

            <!-- Eyebrow + heading -->
            <div class="mb-10">
                <div class="inline-flex items-center gap-2 text-green-600 text-sm font-mono font-medium mb-3 tracking-wider">
                    <span class="text-green-500">>://</span>
                    <span>Serviços relacionados</span>
                </div>
                <h2 class="text-2xl md:text-3xl font-bold text-slate-900">
                    Você também pode precisar de
                </h2>
            </div>

            <!-- Related cards -->
            <div class="grid md:grid-cols-3 gap-6">
                {{#service.related_services}}
                    <a href="{{url}}"
                       class="group flex items-start gap-4 bg-slate-50 rounded-lg border border-slate-200 p-5 hover:shadow-md hover:border-green-200 transition-all duration-200">
                        <div class="w-10 h-10 bg-green-50 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:bg-green-100 transition-colors">
                            <i data-lucide="{{icon}}" class="w-5 h-5 text-green-600"></i>
                        </div>
                        <div class="flex-1">
                            <h3 class="text-sm font-semibold text-slate-900 mb-1 group-hover:text-green-600 transition-colors">
                                {{title}}
                            </h3>
                            <span class="text-xs font-mono text-green-600 inline-flex items-center gap-1">
                                Saiba mais
                                <i data-lucide="arrow-right" class="w-3 h-3 group-hover:translate-x-0.5 transition-transform"></i>
                            </span>
                        </div>
                    </a>
                {{/service.related_services}}
            </div>
        </div>
    </div>
</section>

<!-- CTA SECTION -->
<section class="bg-green-600 py-16">
    <div class="container mx-auto px-4 md:px-8 lg:px-12">
        <div class="max-w-3xl mx-auto text-center">
            <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
                Vamos falar sobre seu projeto?
            </h2>
            <p class="text-green-50 text-lg mb-8 max-w-xl mx-auto leading-relaxed">
                Conte-nos o seu desafio e vamos propor a abordagem mais adequada para alcançar seus objetivos com eficiência e qualidade.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="contact.html"
                   class="inline-block bg-white text-green-600 font-semibold px-8 py-3 rounded-lg hover:bg-green-50 transition-colors shadow-lg">
                    Falar com especialista
                </a>
                <a href="services.html"
                   class="inline-block bg-green-700 text-white font-semibold px-8 py-3 rounded-lg hover:bg-green-800 transition-colors">
                    Ver todos os serviços
                </a>
            </div>
        </div>
    </div>
</section>