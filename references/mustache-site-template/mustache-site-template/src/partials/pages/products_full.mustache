<!-- ══════════════════════════════════════════════════════════════════════════
     PRODUCTS FULL PAGE CONTENT
     ══════════════════════════════════════════════════════════════════════════ -->

<!-- CATEGORY FILTER -->
<section class="bg-white py-6 shadow-sm sticky top-0 z-30 border-b border-slate-100">
    <div class="container mx-auto px-4 md:px-8 lg:px-12">
        <div class="flex flex-wrap gap-2 items-center">
            {{#products_page.filters}}
                <button
                    data-filter="{{id}}"
                    class="px-4 py-2 rounded-full text-sm font-medium font-mono transition-all duration-200
                        {{#active}}bg-green-600 text-white shadow-sm active-filter{{/active}}
                        {{^active}}bg-slate-100 text-slate-600 hover:bg-slate-200{{/active}}">
                    {{label}}
                </button>
            {{/products_page.filters}}
        </div>
    </div>
</section>

<!-- PRODUCTS GRID -->
<section class="bg-slate-950 py-16 lg:py-20">
    <div class="container mx-auto px-4 md:px-8 lg:px-12">

        <!-- Section header -->
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-12">
            <div>
                <div class="inline-flex items-center gap-2 text-green-400 text-sm font-mono font-medium mb-3 tracking-wider">
                    <span class="text-green-500">>://</span>
                    <span>{{products_page.eyebrow}}</span>
                </div>
                <h2 class="text-3xl md:text-4xl font-bold text-white">
                    {{products_page.title}}
                </h2>
            </div>
            <p class="text-slate-500 text-sm font-mono md:text-right leading-relaxed max-w-sm">
                {{products_page.subtitle}}
            </p>
        </div>

        <!-- Cards -->
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6" id="products-grid">
            {{#products_page.items}}
                <div data-category="{{category_id}}"
                     class="group flex flex-col bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden
                            hover:border-green-700/50 transition-all duration-300">

                    <!-- Card header -->
                    <div class="p-6 pb-4">
                        <!-- Icon + status -->
                        <div class="flex items-start justify-between gap-3 mb-5">
                            <div class="w-12 h-12 rounded-xl bg-green-900/30 border border-green-700/30
                                        flex items-center justify-center flex-shrink-0
                                        group-hover:bg-green-900/50 transition-colors duration-300">
                                <i data-lucide="{{icon}}" class="w-6 h-6 text-green-400"></i>
                            </div>
                            <span class="text-xs font-mono px-2.5 py-1 rounded-full border {{status_class}}">
                                {{status_label}}
                            </span>
                        </div>

                        <!-- Name + tagline -->
                        <h3 class="text-xl font-bold text-white mb-1 group-hover:text-green-300 transition-colors duration-200">
                            {{name}}
                        </h3>
                        <p class="text-sm font-mono text-green-400/80 mb-4">
                            {{tagline}}
                        </p>
                        <p class="text-slate-400 text-sm leading-relaxed">
                            {{description}}
                        </p>
                    </div>

                    <!-- Feature list -->
                    <div class="px-6 pb-4 flex-1">
                        <ul class="space-y-2 mt-2">
                            {{#features}}
                                <li class="flex items-start gap-2 text-sm text-slate-400">
                                    <i data-lucide="check" class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5"></i>
                                    <span>{{.}}</span>
                                </li>
                            {{/features}}
                        </ul>
                    </div>

                    <!-- Tags -->
                    <div class="px-6 py-4 border-t border-slate-800/60 flex flex-wrap gap-1.5">
                        {{#tags}}
                            <span class="text-xs font-mono text-slate-500 bg-slate-800 px-2 py-0.5 rounded">{{.}}</span>
                        {{/tags}}
                    </div>

                    <!-- CTA -->
                    <div class="px-6 pb-6">
                        {{#is_available}}
                            <a href="{{url}}"
                               class="flex items-center justify-center gap-2 w-full px-4 py-2.5 rounded-lg
                                      bg-green-600 text-white text-sm font-semibold
                                      hover:bg-green-500 transition-colors duration-200">
                                {{cta}}
                                <i data-lucide="arrow-right" class="w-4 h-4"></i>
                            </a>
                        {{/is_available}}
                        {{^is_available}}
                            <a href="{{url}}"
                               class="flex items-center justify-center gap-2 w-full px-4 py-2.5 rounded-lg
                                      bg-slate-800 text-slate-300 text-sm font-semibold
                                      hover:bg-slate-700 transition-colors duration-200 border border-slate-700">
                                {{cta}}
                                <i data-lucide="bell" class="w-4 h-4"></i>
                            </a>
                        {{/is_available}}
                    </div>

                </div>
            {{/products_page.items}}
        </div>

    </div>
</section>

<!-- ABOUT BUILDING IN PUBLIC -->
<section class="bg-[#0a0a0a] py-16 border-t border-slate-800">
    <div class="container mx-auto px-4 md:px-8 lg:px-12">
        <div class="max-w-3xl mx-auto text-center">
            <div class="inline-flex items-center gap-2 text-green-400 text-sm font-mono font-medium mb-4 tracking-wider">
                <span class="text-green-500">>://</span>
                <span>Como trabalhamos</span>
            </div>
            <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
                Construindo com base em problemas reais
            </h2>
            <p class="text-slate-400 leading-relaxed mb-8">
                Nossos produtos não surgem de especulação — eles nascem da experiência acumulada em dezenas de projetos com clientes reais.
                Cada funcionalidade resolve uma dor concreta que já observamos no campo.
            </p>
            <div class="grid sm:grid-cols-3 gap-6 text-left">
                <div class="bg-slate-900 border border-slate-800 rounded-xl p-5">
                    <div class="w-9 h-9 bg-green-900/30 rounded-lg flex items-center justify-center mb-3">
                        <i data-lucide="users" class="w-5 h-5 text-green-400"></i>
                    </div>
                    <h4 class="text-sm font-semibold text-white mb-1">Co-criação</h4>
                    <p class="text-xs text-slate-500 leading-relaxed">Desenvolvemos junto com os primeiros usuários, incorporando feedback desde o dia um.</p>
                </div>
                <div class="bg-slate-900 border border-slate-800 rounded-xl p-5">
                    <div class="w-9 h-9 bg-green-900/30 rounded-lg flex items-center justify-center mb-3">
                        <i data-lucide="shield-check" class="w-5 h-5 text-green-400"></i>
                    </div>
                    <h4 class="text-sm font-semibold text-white mb-1">Qualidade técnica</h4>
                    <p class="text-xs text-slate-500 leading-relaxed">Mesma arquitetura robusta que entregamos para clientes enterprise — sem atalhos.</p>
                </div>
                <div class="bg-slate-900 border border-slate-800 rounded-xl p-5">
                    <div class="w-9 h-9 bg-green-900/30 rounded-lg flex items-center justify-center mb-3">
                        <i data-lucide="trending-up" class="w-5 h-5 text-green-400"></i>
                    </div>
                    <h4 class="text-sm font-semibold text-white mb-1">Evolução contínua</h4>
                    <p class="text-xs text-slate-500 leading-relaxed">Roadmap público e lançamentos frequentes. Você acompanha cada etapa do desenvolvimento.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA SECTION -->
<section class="bg-green-600 py-16">
    <div class="container mx-auto px-4 md:px-8 lg:px-12">
        <div class="max-w-3xl mx-auto text-center">
            <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
                {{products_page.cta_section.title}}
            </h2>
            <p class="text-green-50 text-lg mb-8 max-w-xl mx-auto leading-relaxed">
                {{products_page.cta_section.subtitle}}
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="contact.html"
                   class="inline-block bg-white text-green-600 font-semibold px-8 py-3 rounded-lg hover:bg-green-50 transition-colors shadow-lg">
                    Falar com a gente
                </a>
                <a href="services.html"
                   class="inline-block bg-green-700 text-white font-semibold px-8 py-3 rounded-lg hover:bg-green-800 transition-colors">
                    Ver serviços
                </a>
            </div>
        </div>
    </div>
</section>

<!-- CATEGORY FILTER SCRIPT -->
<script>
    document.querySelectorAll('[data-filter]').forEach(btn => {
        btn.addEventListener('click', () => {
            const cat = btn.dataset.filter;

            // Update button states
            document.querySelectorAll('[data-filter]').forEach(b => {
                b.classList.remove('active-filter', 'bg-green-600', 'text-white', 'shadow-sm');
                b.classList.add('bg-slate-100', 'text-slate-600');
            });
            btn.classList.add('active-filter', 'bg-green-600', 'text-white', 'shadow-sm');
            btn.classList.remove('bg-slate-100', 'text-slate-600');

            // Filter cards
            document.querySelectorAll('[data-category]').forEach(card => {
                const show = cat === 'all' || card.dataset.category === cat;
                card.style.display = show ? '' : 'none';
            });

            // Re-init Lucide icons
            if (typeof lucide !== 'undefined') lucide.createIcons();
        });
    });
</script>
