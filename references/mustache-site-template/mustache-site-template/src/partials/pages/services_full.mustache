<!-- ══════════════════════════════════════════════════════════════════════════
     SERVICES FULL PAGE CONTENT
     ══════════════════════════════════════════════════════════════════════════ -->

<!-- CATEGORY FILTER -->
<section class="bg-white py-8 shadow-sm sticky top-0 z-30 border-b border-slate-100">
    <div class="container mx-auto px-4 md:px-8 lg:px-12">
        <div class="flex flex-wrap gap-2 items-center">
            {{#services_page.categories}}
                <button
                    data-filter="{{id}}"
                    class="px-4 py-2 rounded-full text-sm font-medium font-mono transition-all duration-200
                        {{#active}}bg-green-600 text-white shadow-sm active-filter{{/active}}
                        {{^active}}bg-slate-100 text-slate-600 hover:bg-slate-200{{/active}}">
                    {{label}}
                </button>
            {{/services_page.categories}}
        </div>
    </div>
</section>

<!-- SERVICES GRID -->
<section class="bg-slate-50 py-16 lg:py-20">
    <div class="container mx-auto px-4 md:px-8 lg:px-12">

        <!-- Section header -->
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-12">
            <div>
                <div class="inline-flex items-center gap-2 text-green-600 text-sm font-mono font-medium mb-3 tracking-wider">
                    <span class="text-green-500">>://</span>
                    <span>{{services_page.eyebrow}}</span>
                </div>
                <h2 class="text-3xl md:text-4xl font-bold text-slate-900">
                    {{services_page.title}}
                </h2>
            </div>
            <p class="text-slate-500 text-sm font-mono md:text-right">
                16 serviços disponíveis
            </p>
        </div>

        <!-- Grid -->
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
            {{#services_page.items}}
                <div data-category="{{category_id}}"
                     class="bg-white rounded-lg border border-slate-200 p-6 flex flex-col hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">

                    <!-- Card top: icon + featured badge -->
                    <div class="flex items-start justify-between mb-4">
                        <div class="w-12 h-12 bg-green-50 rounded-lg flex items-center justify-center flex-shrink-0">
                            <i data-lucide="{{icon}}" class="w-6 h-6 text-green-600"></i>
                        </div>
                        {{#featured}}
                            <span class="inline-flex items-center gap-1 bg-green-50 text-green-700 text-xs font-mono font-semibold px-2.5 py-1 rounded-full border border-green-200">
                                <i data-lucide="star" class="w-3 h-3"></i>
                                Destaque
                            </span>
                        {{/featured}}
                    </div>

                    <!-- Title -->
                    <h3 class="text-lg font-semibold text-slate-900 mb-3">
                        {{title}}
                    </h3>

                    <!-- Tags -->
                    <div class="flex flex-wrap gap-1.5 mb-4">
                        {{#tags}}
                            <span class="text-xs font-mono text-slate-500 bg-slate-100 px-2 py-0.5 rounded">
                                {{.}}
                            </span>
                        {{/tags}}
                    </div>

                    <!-- Description -->
                    <p class="text-sm text-slate-600 leading-relaxed flex-1 mb-6">
                        {{description}}
                    </p>

                    <!-- Link -->
                    <a href="{{url}}"
                       class="inline-flex items-center gap-1.5 text-green-600 text-sm font-semibold hover:text-green-700 transition-colors group mt-auto">
                        Saiba mais
                        <i data-lucide="arrow-right" class="w-4 h-4 group-hover:translate-x-1 transition-transform"></i>
                    </a>
                </div>
            {{/services_page.items}}
        </div>
    </div>
</section>

<!-- CTA SECTION -->
<section class="bg-green-600 py-16">
    <div class="container mx-auto px-4 md:px-8 lg:px-12">
        <div class="max-w-3xl mx-auto text-center">
            <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
                {{services_page.cta_section.title}}
            </h2>
            <p class="text-green-50 text-lg mb-8 max-w-xl mx-auto leading-relaxed">
                {{services_page.cta_section.subtitle}}
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
                <a href="contact.html"
                   class="inline-block bg-white text-green-600 font-semibold px-8 py-3 rounded-lg hover:bg-green-50 transition-colors shadow-lg">
                    Falar com especialista
                </a>
                <a href="index.html#portfolio"
                   class="inline-block bg-green-700 text-white font-semibold px-8 py-3 rounded-lg hover:bg-green-800 transition-colors">
                    Ver portfólio
                </a>
            </div>
        </div>
    </div>
</section>

<!-- CATEGORY FILTER SCRIPT -->
<script>
    document.querySelectorAll('[data-filter]').forEach(btn => {
        btn.addEventListener('click', () => {
            const cat = btn.dataset.filter;
            document.querySelectorAll('[data-filter]').forEach(b => {
                b.classList.remove('active-filter', 'bg-green-600', 'text-white', 'shadow-sm');
                b.classList.add('bg-slate-100', 'text-slate-600');
            });
            btn.classList.add('active-filter', 'bg-green-600', 'text-white', 'shadow-sm');
            btn.classList.remove('bg-slate-100', 'text-slate-600');
            document.querySelectorAll('[data-category]').forEach(card => {
                card.style.display = (cat === 'all' || card.dataset.category === cat) ? '' : 'none';
            });
        });
    });
</script>