<!-- ============================================================
   FOOTER — Multi-column footer + bottom bar (dark)
   Inspired by Presento + charityhope bottom bar
   Data keys: site.*, footer.description, .quick_links[],
              .service_links[], .bottom_bar{}
   ============================================================ -->
<!-- Footer main -->
<footer class="bg-[#0a0a0a] border-t border-slate-800/60">
  <div class="container mx-auto px-4 md:px-8 lg:px-12 py-14">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Col 1: Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href="#hero" class="inline-block mb-4">
          <img src="{{site.logo_dark}}" alt="{{site.company_name}}" class="h-10 w-auto" loading="lazy" />
        </a>
        <p class="text-slate-500 text-sm leading-relaxed mb-5 max-w-xs">
          {{footer.description}}
        </p>
        <div class="font-mono text-xs text-green-700 opacity-60">
          <span>new Stacktrace();</span>
        </div>
      </div>

      <!-- Col 2: Quick links -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-4">Navegação</h4>
        <ul class="space-y-2.5">
          {{#footer.quick_links}}
          <li>
            <a href="{{url}}"
               class="text-slate-500 hover:text-green-400 text-sm transition-colors duration-200 flex items-center gap-1.5 group">
              <i data-lucide="chevron-right" class="w-3 h-3 text-green-700 opacity-0 group-hover:opacity-100 transition-opacity duration-200"></i>
              {{label}}
            </a>
          </li>
          {{/footer.quick_links}}
        </ul>
      </div>

      <!-- Col 3: Services -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-4">Serviços</h4>
        <ul class="space-y-2.5">
          {{#footer.service_links}}
          <li>
            <a href="{{url}}"
               class="text-slate-500 hover:text-green-400 text-sm transition-colors duration-200 flex items-center gap-1.5 group">
              <i data-lucide="chevron-right" class="w-3 h-3 text-green-700 opacity-0 group-hover:opacity-100 transition-opacity duration-200"></i>
              {{label}}
            </a>
          </li>
          {{/footer.service_links}}
        </ul>
      </div>

      <!-- Col 4: Contact summary -->
      <div>
        <h4 class="text-white font-semibold text-sm mb-4">Contato</h4>
        <ul class="space-y-3">
          <li class="flex items-start gap-2 text-slate-500 text-sm">
            <i data-lucide="mail" class="w-4 h-4 text-green-700 flex-shrink-0 mt-0.5"></i>
            <a href="mailto:{{site.email}}" class="hover:text-green-400 transition-colors duration-200 break-all">{{site.email}}</a>
          </li>
          <li class="flex items-start gap-2 text-slate-500 text-sm">
            <i data-lucide="phone" class="w-4 h-4 text-green-700 flex-shrink-0 mt-0.5"></i>
            <a href="tel:{{site.phone}}" class="hover:text-green-400 transition-colors duration-200">{{site.phone}}</a>
          </li>
          <li class="flex items-start gap-2 text-slate-500 text-sm">
            <i data-lucide="map-pin" class="w-4 h-4 text-green-700 flex-shrink-0 mt-0.5"></i>
            <span>{{site.address}}</span>
          </li>
        </ul>
        <!-- Social mini row -->
        <div class="flex items-center gap-2 mt-5">
          <a href="{{site.social.linkedin}}" target="_blank" rel="noopener noreferrer"
             class="text-slate-600 hover:text-green-400 transition-colors duration-200" aria-label="LinkedIn">
            <i data-lucide="linkedin" class="w-4 h-4"></i>
          </a>
          <a href="{{site.social.github}}" target="_blank" rel="noopener noreferrer"
             class="text-slate-600 hover:text-green-400 transition-colors duration-200" aria-label="GitHub">
            <i data-lucide="github" class="w-4 h-4"></i>
          </a>
          <a href="{{site.social.instagram}}" target="_blank" rel="noopener noreferrer"
             class="text-slate-600 hover:text-green-400 transition-colors duration-200" aria-label="Instagram">
            <i data-lucide="instagram" class="w-4 h-4"></i>
          </a>
        </div>
      </div>

    </div>
  </div>

  <!-- Bottom bar — inspired by charityhope -->
  <div class="border-t border-slate-800/60">
    <div class="container mx-auto px-4 md:px-8 lg:px-12">
      <div class="flex flex-col sm:flex-row items-center justify-between gap-3 py-5">
        <p class="text-slate-600 text-xs">
          {{footer.bottom_bar.copyright}}
        </p>
        <div class="flex items-center gap-4">
          {{#footer.bottom_bar.links}}
          <a href="{{url}}"
             class="text-slate-600 hover:text-slate-400 text-xs transition-colors duration-200">
            {{label}}
          </a>
          {{/footer.bottom_bar.links}}
        </div>
      </div>
    </div>
  </div>

</footer>
