<!-- ============================================================
   TOPBAR — inspired by Clinic-1.0.0
   Data keys: site.email, site.phone, site.social.*
   ============================================================ -->
<div id="topbar" class="bg-[#0a0a0a] border-b border-slate-800/60 text-slate-400 text-sm">
  <div class="container mx-auto px-4 md:px-8 lg:px-12">
    <div class="flex items-center justify-between h-10">

      <!-- Contact info -->
      <div class="flex items-center gap-6">
        <a href="mailto:{{site.email}}"
           class="flex items-center gap-1.5 hover:text-green-500 transition-colors duration-200 group">
          <i data-lucide="mail" class="w-3.5 h-3.5 text-green-600 group-hover:text-green-400"></i>
          <span>{{site.email}}</span>
        </a>
        <a href="tel:{{site.phone}}"
           class="hidden sm:flex items-center gap-1.5 hover:text-green-500 transition-colors duration-200 group">
          <i data-lucide="phone" class="w-3.5 h-3.5 text-green-600 group-hover:text-green-400"></i>
          <span>{{site.phone}}</span>
        </a>
      </div>

      <!-- Social links -->
      <div class="hidden md:flex items-center gap-3">
        <a href="{{site.social.linkedin}}" target="_blank" rel="noopener noreferrer"
           class="w-7 h-7 flex items-center justify-center rounded hover:bg-green-600/10 hover:text-green-400 transition-all duration-200"
           aria-label="LinkedIn">
          <i data-lucide="linkedin" class="w-3.5 h-3.5"></i>
        </a>
        <a href="{{site.social.github}}" target="_blank" rel="noopener noreferrer"
           class="w-7 h-7 flex items-center justify-center rounded hover:bg-green-600/10 hover:text-green-400 transition-all duration-200"
           aria-label="GitHub">
          <i data-lucide="github" class="w-3.5 h-3.5"></i>
        </a>
        <a href="{{site.social.instagram}}" target="_blank" rel="noopener noreferrer"
           class="w-7 h-7 flex items-center justify-center rounded hover:bg-green-600/10 hover:text-green-400 transition-all duration-200"
           aria-label="Instagram">
          <i data-lucide="instagram" class="w-3.5 h-3.5"></i>
        </a>
        <a href="{{site.social.twitter}}" target="_blank" rel="noopener noreferrer"
           class="w-7 h-7 flex items-center justify-center rounded hover:bg-green-600/10 hover:text-green-400 transition-all duration-200"
           aria-label="Twitter / X">
          <i data-lucide="twitter" class="w-3.5 h-3.5"></i>
        </a>
      </div>

    </div>
  </div>
</div>
