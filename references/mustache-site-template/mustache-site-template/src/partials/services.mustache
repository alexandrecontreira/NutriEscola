<!-- ============================================================
   SERVICES — Service cards grid (dark section)
   Inspired by Presento + KnightOne service layouts
   Data keys: services.eyebrow, .title, .subtitle, .items[]
              item: .icon, .title, .description, .tags[], .url
   ============================================================ -->
<section id="services" class="py-20 lg:py-28 bg-slate-900">
  <div class="container mx-auto px-4 md:px-8 lg:px-12">

    <!-- Section header -->
    <div class="max-w-2xl mb-14 reveal">
      <div class="inline-flex items-center gap-2 text-green-400 text-sm font-mono font-medium mb-4 tracking-wider">
        <span class="text-green-500">>://</span>
        <span>{{services.eyebrow}}</span>
      </div>
      <h2 class="text-3xl lg:text-4xl font-bold text-white leading-tight mb-4">
        {{services.title}}
      </h2>
      <p class="text-slate-400 text-base lg:text-lg leading-relaxed">
        {{services.subtitle}}
      </p>
      <div class="w-12 h-1 bg-green-600 rounded-full mt-6"></div>
    </div>

    <!-- Services grid -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {{#services.items}}
      <article class="reveal group relative bg-slate-800/40 border border-slate-700/50 rounded-2xl p-6 hover:border-green-600/40 hover:bg-slate-800/70 transition-all duration-300 overflow-hidden">

        <!-- Hover glow -->
        <div class="absolute inset-0 bg-gradient-to-br from-green-600/0 via-transparent to-green-600/0 group-hover:from-green-600/5 group-hover:to-green-600/3 transition-all duration-300 rounded-2xl pointer-events-none"></div>

        <!-- Icon -->
        <div class="w-12 h-12 flex items-center justify-center bg-green-600/10 border border-green-600/20 rounded-xl mb-5 group-hover:bg-green-600/20 group-hover:border-green-600/40 transition-all duration-300">
          <i data-lucide="{{icon}}" class="w-6 h-6 text-green-500 group-hover:text-green-400 transition-colors duration-200"></i>
        </div>

        <!-- Content -->
        <h3 class="text-white font-bold text-lg mb-3 group-hover:text-green-100 transition-colors duration-200">
          {{title}}
        </h3>
        <p class="text-slate-400 text-sm leading-relaxed mb-5">
          {{description}}
        </p>

        <!-- Tags -->
        <div class="flex flex-wrap gap-1.5 mb-5">
          {{#tags}}
          <span class="px-2 py-0.5 bg-slate-700/60 text-slate-400 text-xs font-mono rounded border border-slate-600/40">
            {{.}}
          </span>
          {{/tags}}
        </div>

        <!-- CTA link -->
        <a href="{{url}}"
           class="inline-flex items-center gap-1.5 text-green-500 text-sm font-medium hover:text-green-400 transition-colors duration-200 group/link">
          Saiba mais
          <i data-lucide="arrow-right" class="w-3.5 h-3.5 transition-transform duration-200 group-hover/link:translate-x-1"></i>
        </a>

      </article>
      {{/services.items}}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-12 reveal">
      <p class="text-slate-400 text-sm mb-4">Precisa de algo mais específico?</p>
        <a href="services.html"
           class="inline-flex items-center gap-2 px-6 py-3 bg-green-600 hover:bg-green-500 text-white font-semibold rounded-lg transition-all duration-200 shadow-lg shadow-green-900/30">
            Ver serviços
            <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </a>
        <a href="#contact"
         class="inline-flex items-center gap-2 px-6 py-3 bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 text-slate-200 font-semibold rounded-lg transition-all duration-200">
        Falar com especialista
<!--        <i data-lucide="arrow-right" class="w-4 h-4"></i>-->
      </a>
    </div>

  </div>
</section>
