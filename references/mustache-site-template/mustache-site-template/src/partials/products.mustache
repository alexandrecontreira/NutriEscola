<!-- ============================================================
   PRODUCTS — Own product cards (dark section)
   Data keys: products.eyebrow, .title, .subtitle, .items[]
              item: .name, .tagline, .description, .icon,
                    .status_label, .status_class, .is_available,
                    .tags[], .url, .cta
   ============================================================ -->
<section id="products" class="py-20 lg:py-28 bg-slate-900">
  <div class="container mx-auto px-4 md:px-8 lg:px-12">

    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-14 reveal">
      <div class="inline-flex items-center gap-2 text-green-400 text-sm font-mono font-medium mb-4 tracking-wider">
        <span class="text-green-500">>://</span>
        <span>{{products.eyebrow}}</span>
      </div>
      <h2 class="text-3xl lg:text-4xl font-bold text-white leading-tight mb-4">
        {{products.title}}
      </h2>
      <p class="text-slate-400 text-base leading-relaxed">
        {{products.subtitle}}
      </p>
      <div class="w-12 h-1 bg-green-600 rounded-full mx-auto mt-6"></div>
    </div>

    <!-- Products grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
      {{#products.items}}
      <article class="reveal group relative bg-slate-800/40 border border-slate-700/50 rounded-2xl p-7 flex flex-col hover:border-green-600/30 transition-all duration-300 overflow-hidden">

        <!-- Subtle corner glow -->
        <div class="absolute top-0 right-0 w-32 h-32 bg-green-600/5 rounded-full blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none -translate-y-1/2 translate-x-1/2"></div>

        <!-- Header row: icon + status badge -->
        <div class="flex items-start justify-between gap-4 mb-5">
          <div class="w-12 h-12 flex items-center justify-center bg-green-600/10 border border-green-600/20 rounded-xl group-hover:bg-green-600/20 transition-all duration-200">
            <i data-lucide="{{icon}}" class="w-6 h-6 text-green-500"></i>
          </div>
          <span class="inline-flex px-2.5 py-1 text-xs font-mono font-medium rounded-full {{status_class}} flex-shrink-0 mt-0.5">
            {{status_label}}
          </span>
        </div>

        <!-- Name + tagline -->
        <h3 class="text-white font-bold text-xl mb-1">{{name}}</h3>
        <p class="text-green-400 text-sm font-medium mb-3 font-mono">{{tagline}}</p>

        <!-- Description -->
        <p class="text-slate-400 text-sm leading-relaxed mb-5 flex-1">
          {{description}}
        </p>

        <!-- Tech/category tags -->
        <div class="flex flex-wrap gap-1.5 mb-6">
          {{#tags}}
          <span class="px-2 py-0.5 bg-slate-700/60 text-slate-400 text-xs font-mono rounded border border-slate-600/40">{{.}}</span>
          {{/tags}}
        </div>

        <!-- CTA -->
        {{#is_available}}
        <a href="{{url}}"
           class="inline-flex items-center justify-center gap-2 w-full py-2.5 bg-green-600 hover:bg-green-500 text-white text-sm font-semibold rounded-lg transition-all duration-200">
          {{cta}}
          <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </a>
        {{/is_available}}
        {{^is_available}}
        <a href="{{url}}"
           class="inline-flex items-center justify-center gap-2 w-full py-2.5 bg-white/5 hover:bg-white/10 border border-slate-600/50 hover:border-slate-500/60 text-slate-300 text-sm font-medium rounded-lg transition-all duration-200">
          {{cta}}
          <i data-lucide="bell" class="w-4 h-4"></i>
        </a>
        {{/is_available}}

      </article>
      {{/products.items}}
    </div>

    <!-- Footnote -->
    <p class="text-center text-slate-500 text-sm mt-10 reveal font-mono">
      <span class="text-green-600">://</span> Mais produtos em desenvolvimento. Acompanhe nossas novidades.
    </p>

  </div>
</section>
