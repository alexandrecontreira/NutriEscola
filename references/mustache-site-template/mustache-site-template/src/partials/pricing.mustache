<!-- ============================================================
   PRICING — Plan cards with tabs (light section)
   Supports: fixed price, "sob consulta", free, highlighted plan
   Data keys: pricing.eyebrow, .title, .subtitle, .tab_groups[]
              group: .id, .label, .active, .plans[]
              plan: .name, .price, .price_note, .is_highlight,
                    .description, .features[], .cta_label, .cta_url
   JS: assets/js/main.js → pricingTabs()
   ============================================================ -->
<section id="pricing" class="py-20 lg:py-28 bg-white">
  <div class="container mx-auto px-4 md:px-8 lg:px-12">

    <!-- Section header -->
    <div class="text-center max-w-2xl mx-auto mb-10 reveal">
      <div class="inline-flex items-center gap-2 text-green-600 text-sm font-mono font-medium mb-4 tracking-wider">
        <span>>://</span>
        <span>{{pricing.eyebrow}}</span>
      </div>
      <h2 class="text-3xl lg:text-4xl font-bold text-slate-900 leading-tight mb-4">
        {{pricing.title}}
      </h2>
      <p class="text-slate-500 text-base leading-relaxed">
        {{pricing.subtitle}}
      </p>
      <div class="w-12 h-1 bg-green-600 rounded-full mx-auto mt-6"></div>
    </div>

    <!-- Tab buttons -->
    <div class="flex justify-center mb-10 reveal">
      <div class="inline-flex p-1 bg-slate-100 rounded-xl gap-1">
        {{#pricing.tab_groups}}
        <button class="pricing-tab px-5 py-2.5 text-sm font-medium rounded-lg transition-all duration-200
                       {{#active}}bg-white text-slate-900 shadow-sm{{/active}}
                       {{^active}}text-slate-500 hover:text-slate-700{{/active}}"
                data-target="{{id}}"
                role="tab"
                aria-selected="{{active}}">
          {{label}}
        </button>
        {{/pricing.tab_groups}}
      </div>
    </div>

    <!-- Tab content panels -->
    {{#pricing.tab_groups}}
    <div id="pricing-{{id}}"
         class="pricing-tab-content{{^active}} hidden{{/active}}"
         role="tabpanel">
      <div class="grid md:grid-cols-3 gap-6 items-stretch">
        {{#plans}}

        <!-- HIGHLIGHTED PLAN -->
        {{#is_highlight}}
        <div class="reveal relative bg-slate-900 border-2 border-green-600 rounded-2xl p-7 flex flex-col shadow-xl shadow-green-900/20 md:-translate-y-2">
          <!-- Popular badge -->
          <div class="absolute -top-3.5 left-1/2 -translate-x-1/2">
            <span class="inline-flex items-center gap-1.5 px-4 py-1.5 bg-green-600 text-white text-xs font-bold rounded-full shadow-lg shadow-green-900/40">
              <i data-lucide="zap" class="w-3 h-3"></i>
              Mais escolhido
            </span>
          </div>

          <div class="mb-6 pt-2">
            <h3 class="text-white font-bold text-xl mb-1">{{name}}</h3>
            <p class="text-green-400 text-sm leading-relaxed">{{description}}</p>
          </div>

          <div class="mb-6">
            <div class="text-white font-bold text-3xl lg:text-4xl">{{price}}</div>
            <div class="text-slate-400 text-sm mt-0.5 font-mono">{{price_note}}</div>
          </div>

          <ul class="space-y-3 mb-7 flex-1">
            {{#features}}
            <li class="flex items-start gap-2.5 text-sm text-slate-300">
              <i data-lucide="check-circle-2" class="w-4 h-4 text-green-500 flex-shrink-0 mt-0.5"></i>
              <span>{{text}}</span>
            </li>
            {{/features}}
          </ul>

          <a href="{{cta_url}}"
             class="inline-flex items-center justify-center gap-2 w-full py-3 bg-green-600 hover:bg-green-500 text-white font-semibold rounded-xl transition-all duration-200 shadow-lg shadow-green-900/40">
            {{cta_label}}
            <i data-lucide="arrow-right" class="w-4 h-4"></i>
          </a>
        </div>
        {{/is_highlight}}

        <!-- REGULAR PLAN -->
        {{^is_highlight}}
        <div class="reveal bg-white border border-slate-200 rounded-2xl p-7 flex flex-col hover:border-green-300 hover:shadow-lg hover:shadow-green-50 transition-all duration-300">

          <div class="mb-6">
            <h3 class="text-slate-900 font-bold text-xl mb-1">{{name}}</h3>
            <p class="text-slate-500 text-sm leading-relaxed">{{description}}</p>
          </div>

          <div class="mb-6">
            <div class="text-slate-900 font-bold text-3xl lg:text-4xl">{{price}}</div>
            <div class="text-slate-400 text-sm mt-0.5 font-mono">{{price_note}}</div>
          </div>

          <ul class="space-y-3 mb-7 flex-1">
            {{#features}}
            <li class="flex items-start gap-2.5 text-sm text-slate-600">
              <i data-lucide="check" class="w-4 h-4 text-green-600 flex-shrink-0 mt-0.5"></i>
              <span>{{text}}</span>
            </li>
            {{/features}}
          </ul>

          <a href="{{cta_url}}"
             class="inline-flex items-center justify-center gap-2 w-full py-3 border-2 border-slate-200 hover:border-green-500 hover:bg-green-50 hover:text-green-700 text-slate-700 font-semibold rounded-xl transition-all duration-200">
            {{cta_label}}
            <i data-lucide="arrow-right" class="w-4 h-4"></i>
          </a>
        </div>
        {{/is_highlight}}

        {{/plans}}
      </div>

      <!-- Footnote inside tab panel -->
      <p class="text-center text-slate-400 text-sm mt-8 reveal">
        Precisa de algo personalizado?
        <a href="#contact" class="text-green-600 font-medium hover:text-green-700 underline decoration-green-200 hover:decoration-green-400 transition-colors duration-200 ml-1">
          Entre em contato para uma proposta sob medida.
        </a>
      </p>
    </div>
    {{/pricing.tab_groups}}

  </div>
</section>
