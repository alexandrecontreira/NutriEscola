<!-- ============================================================
   HERO — Slider inspired by Presento + charityhope carousel
   Visual: dark terminal aesthetic with brand identity
   Data keys: hero.slides[].id, .active, .eyebrow, .title,
              .subtitle, .cta_primary, .cta_secondary
   JS: assets/js/main.js → heroSlider()
   ============================================================ -->
<section id="hero" class="relative min-h-screen bg-[#0a0a0a] overflow-hidden flex flex-col">

  <!-- Background grid pattern -->
  <div class="absolute inset-0 hero-grid-pattern opacity-40 pointer-events-none"></div>

  <!-- Green radial glow -->
  <div class="absolute top-1/3 left-1/4 w-[600px] h-[600px] bg-green-600/5 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 right-1/4 w-[400px] h-[400px] bg-green-600/3 rounded-full blur-3xl pointer-events-none"></div>

  <!-- Slides container -->
  <div class="hero-slides-wrapper relative flex-1 flex items-center">
    {{#hero.slides}}
    <div class="hero-slide absolute inset-0 flex items-center{{#active}} active{{/active}}"
         data-slide-id="{{id}}"{{#active}} data-active="true"{{/active}}>>
      <div class="container mx-auto px-4 md:px-8 lg:px-12 w-full">
        <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center py-10 lg:py-20">

          <!-- Text content -->
          <div class="reveal-hero order-2 lg:order-1">
            <!-- Eyebrow badge -->
            <div class="inline-flex items-center gap-2 px-3 py-1.5 bg-green-600/10 border border-green-600/20 rounded-full mb-6">
              <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
              <span class="text-green-400 text-xs font-mono font-medium tracking-wider uppercase">{{eyebrow}}</span>
            </div>

            <!-- Main heading -->
            <h1 class="text-2xl sm:text-5xl lg:text-5xl xl:text-6xl font-bold text-white leading-tight mb-6">
              {{title}}
            </h1>

            <!-- Subtitle -->
            <p class="text-base lg:text-lg text-slate-400 leading-relaxed max-w-xl mb-8">
              {{subtitle}}
            </p>

            <!-- CTAs -->
            <div class="flex flex-wrap gap-4">
              <a href="{{cta_primary.url}}"
                 class="inline-flex items-center gap-2 px-6 py-3 bg-green-600 hover:bg-green-500 text-white font-semibold rounded-lg transition-all duration-200 shadow-lg shadow-green-900/30 hover:shadow-green-900/50 hover:-translate-y-0.5">
                {{cta_primary.label}}
                <i data-lucide="arrow-right" class="w-4 h-4"></i>
              </a>
              <a href="{{cta_secondary.url}}"
                 class="inline-flex items-center gap-2 px-6 py-3 bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 text-slate-200 font-semibold rounded-lg transition-all duration-200 hover:-translate-y-0.5">
                {{cta_secondary.label}}
              </a>
            </div>
          </div>

          <!-- Terminal decoration (static, all slides) -->
          <div id="terminal" class="order-1 lg:order-2 flex justify-center lg:justify-end">
            <div class="w-full max-w-md">
              <!-- Terminal window -->
              <div class="bg-slate-900/80 border border-slate-700/50 rounded-xl backdrop-blur-sm overflow-hidden shadow-2xl shadow-black/50">
                <!-- Title bar -->
                <div class="flex items-center gap-2 px-4 py-3 bg-slate-800/60 border-b border-slate-700/50">
                  <span class="w-3 h-3 rounded-full bg-red-500/80"></span>
                  <span class="w-3 h-3 rounded-full bg-yellow-500/80"></span>
                  <span class="w-3 h-3 rounded-full bg-green-500/80"></span>
                  <span class="ml-3 text-slate-500 text-xs font-mono">~/newstacktrace — bash</span>
                </div>
                <!-- Terminal content -->
                <div class="p-5 font-mono text-sm space-y-2 min-h-[220px]">
                  <div class="flex items-start gap-2">
                    <span class="text-green-500 flex-shrink-0">❯</span>
                    <span><span class="text-slate-500">new</span> <span class="text-white">Stacktrace()</span></span>
                  </div>
                  <div class="pl-5 space-y-1.5 text-slate-400">
                    <div class="flex items-center gap-2">
                      <i data-lucide="check" class="w-3.5 h-3.5 text-green-500 flex-shrink-0"></i>
                      <span>Cloud infrastructure <span class="text-green-400">ready</span></span>
                    </div>
                    <div class="flex items-center gap-2">
                      <i data-lucide="check" class="w-3.5 h-3.5 text-green-500 flex-shrink-0"></i>
                      <span>Engineering team <span class="text-green-400">online</span></span>
                    </div>
                    <div class="flex items-center gap-2">
                      <i data-lucide="check" class="w-3.5 h-3.5 text-green-500 flex-shrink-0"></i>
                      <span>AI modules <span class="text-green-400">loaded</span></span>
                    </div>
                    <div class="flex items-center gap-2">
                      <i data-lucide="check" class="w-3.5 h-3.5 text-green-500 flex-shrink-0"></i>
                      <span>DevOps pipeline <span class="text-green-400">active</span></span>
                    </div>
                  </div>
                  <div class="flex items-start gap-2">
                    <span class="text-green-500 flex-shrink-0">❯</span>
                    <span>
                      <span class="text-slate-500">await</span>
                      <span class="text-white"> deliver</span><span class="text-slate-400">(</span><span class="text-green-300">"excellence"</span><span class="text-slate-400">)</span>
                    </span>
                  </div>
                  <div class="pl-5 text-green-400 font-bold">true</div>
                  <div class="flex items-center gap-2">
                    <span class="text-green-500">❯</span>
                    <span class="cursor-blink text-green-400">█</span>
                  </div>
                </div>
              </div>
              <!-- Floating badge below terminal -->
              <div class="flex justify-end mt-3">
                <div class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-slate-800/80 border border-slate-700/50 rounded-full text-xs text-slate-400 font-mono backdrop-blur-sm">
                  <span class="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse"></span>
                  sistema operacional
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
    {{/hero.slides}}
  </div>

  <!-- Slide controls -->
  <div class="relative container mx-auto px-4 md:px-8 lg:px-12">
    <div class="flex items-center justify-between pb-8 lg:pb-10">

      <!-- Slide dots -->
      <div class="flex items-center gap-2" role="tablist" aria-label="Hero slides">
        {{#hero.slides}}
        <button class="hero-dot transition-all duration-300 h-1.5 rounded-full bg-white/20 hover:bg-white/40 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2 focus:ring-offset-[#0a0a0a]
                        {{#active}}w-8 bg-green-500 hover:bg-green-400{{/active}}{{^active}}w-2{{/active}}"
                data-target="{{id}}"
                role="tab"
                aria-selected="{{active}}"
                aria-label="Slide {{id}}">
        </button>
        {{/hero.slides}}
      </div>

      <!-- Prev / Next arrows -->
      <div class="flex items-center gap-2">
        <button class="hero-prev w-9 h-9 flex items-center justify-center border border-white/10 hover:border-green-500/50 hover:bg-green-600/10 rounded-full text-slate-400 hover:text-green-400 transition-all duration-200"
                aria-label="Slide anterior">
          <i data-lucide="chevron-left" class="w-4 h-4"></i>
        </button>
        <button class="hero-next w-9 h-9 flex items-center justify-center border border-white/10 hover:border-green-500/50 hover:bg-green-600/10 rounded-full text-slate-400 hover:text-green-400 transition-all duration-200"
                aria-label="Próximo slide">
          <i data-lucide="chevron-right" class="w-4 h-4"></i>
        </button>
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-4 left-1/2 -translate-x-1/2 hidden lg:flex flex-col items-center gap-1.5 text-slate-600 animate-bounce">
    <span class="text-xs font-mono tracking-widest uppercase">scroll</span>
    <i data-lucide="chevron-down" class="w-4 h-4"></i>
  </div>

</section>
