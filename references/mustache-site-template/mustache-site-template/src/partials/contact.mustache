<!-- ============================================================
   CONTACT SECTION — Info + inline mini-form (dark)
   Data keys: site.email, .phone, .address, .social.*
   ============================================================ -->
<section id="contact" class="py-20 lg:py-24 bg-slate-900 border-t border-slate-800/60">
  <div class="container mx-auto px-4 md:px-8 lg:px-12">
    <div class="grid lg:grid-cols-2 gap-12 xl:gap-20 items-start">

      <!-- Left: Contact info -->
      <div class="reveal">
        <div class="inline-flex items-center gap-2 text-green-400 text-sm font-mono font-medium mb-4 tracking-wider">
          <span class="text-green-500">>://</span>
          <span>Contato</span>
        </div>
        <h2 class="text-3xl lg:text-4xl font-bold text-white mb-4">
          Vamos construir algo juntos?
        </h2>
        <p class="text-slate-400 text-base leading-relaxed mb-8 max-w-md">
          Conta pra gente seu desafio. A primeira conversa é gratuita e sem compromisso — a ideia é entender se faz sentido trabalharmos juntos.
        </p>

        <div class="space-y-4">
          <a href="mailto:{{site.email}}"
             class="flex items-center gap-3 text-slate-300 hover:text-green-400 transition-colors duration-200 group">
            <div class="w-10 h-10 flex items-center justify-center bg-green-600/10 border border-green-600/20 rounded-lg group-hover:bg-green-600/20 transition-all duration-200">
              <i data-lucide="mail" class="w-5 h-5 text-green-500"></i>
            </div>
            <span>{{site.email}}</span>
          </a>
          <a href="tel:{{site.phone}}"
             class="flex items-center gap-3 text-slate-300 hover:text-green-400 transition-colors duration-200 group">
            <div class="w-10 h-10 flex items-center justify-center bg-green-600/10 border border-green-600/20 rounded-lg group-hover:bg-green-600/20 transition-all duration-200">
              <i data-lucide="phone" class="w-5 h-5 text-green-500"></i>
            </div>
            <span>{{site.phone}}</span>
          </a>
          <div class="flex items-center gap-3 text-slate-400">
            <div class="w-10 h-10 flex items-center justify-center bg-slate-800 border border-slate-700 rounded-lg">
              <i data-lucide="map-pin" class="w-5 h-5 text-slate-500"></i>
            </div>
            <span>{{site.address}}</span>
          </div>
        </div>

        <!-- Social links -->
        <div class="flex items-center gap-3 mt-8">
          <a href="{{site.social.linkedin}}" target="_blank" rel="noopener noreferrer"
             class="w-10 h-10 flex items-center justify-center bg-slate-800 border border-slate-700 hover:border-green-600/50 hover:bg-green-600/10 text-slate-400 hover:text-green-400 rounded-lg transition-all duration-200"
             aria-label="LinkedIn">
            <i data-lucide="linkedin" class="w-4 h-4"></i>
          </a>
          <a href="{{site.social.github}}" target="_blank" rel="noopener noreferrer"
             class="w-10 h-10 flex items-center justify-center bg-slate-800 border border-slate-700 hover:border-green-600/50 hover:bg-green-600/10 text-slate-400 hover:text-green-400 rounded-lg transition-all duration-200"
             aria-label="GitHub">
            <i data-lucide="github" class="w-4 h-4"></i>
          </a>
          <a href="{{site.social.instagram}}" target="_blank" rel="noopener noreferrer"
             class="w-10 h-10 flex items-center justify-center bg-slate-800 border border-slate-700 hover:border-green-600/50 hover:bg-green-600/10 text-slate-400 hover:text-green-400 rounded-lg transition-all duration-200"
             aria-label="Instagram">
            <i data-lucide="instagram" class="w-4 h-4"></i>
          </a>
          <a href="{{site.social.twitter}}" target="_blank" rel="noopener noreferrer"
             class="w-10 h-10 flex items-center justify-center bg-slate-800 border border-slate-700 hover:border-green-600/50 hover:bg-green-600/10 text-slate-400 hover:text-green-400 rounded-lg transition-all duration-200"
             aria-label="Twitter / X">
            <i data-lucide="twitter" class="w-4 h-4"></i>
          </a>
        </div>
      </div>

      <!-- Right: Contact form -->
      <div class="reveal">
        <form class="space-y-4 bg-slate-800/40 border border-slate-700/50 rounded-2xl p-7" novalidate>
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label for="contact-name" class="block text-slate-300 text-sm font-medium mb-1.5">Nome</label>
              <input id="contact-name" type="text" name="name" placeholder="Seu nome"
                     class="w-full px-4 py-2.5 bg-slate-700/50 border border-slate-600/50 focus:border-green-600/60 text-white placeholder:text-slate-500 rounded-lg outline-none transition-all duration-200 text-sm" />
            </div>
            <div>
              <label for="contact-email" class="block text-slate-300 text-sm font-medium mb-1.5">E-mail</label>
              <input id="contact-email" type="email" name="email" placeholder="seu@email.com"
                     class="w-full px-4 py-2.5 bg-slate-700/50 border border-slate-600/50 focus:border-green-600/60 text-white placeholder:text-slate-500 rounded-lg outline-none transition-all duration-200 text-sm" />
            </div>
          </div>
          <div>
            <label for="contact-company" class="block text-slate-300 text-sm font-medium mb-1.5">Empresa <span class="text-slate-500 font-normal">(opcional)</span></label>
            <input id="contact-company" type="text" name="company" placeholder="Nome da empresa"
                   class="w-full px-4 py-2.5 bg-slate-700/50 border border-slate-600/50 focus:border-green-600/60 text-white placeholder:text-slate-500 rounded-lg outline-none transition-all duration-200 text-sm" />
          </div>
          <div>
            <label for="contact-subject" class="block text-slate-300 text-sm font-medium mb-1.5">Assunto</label>
            <select id="contact-subject" name="subject"
                    class="w-full px-4 py-2.5 bg-slate-700/50 border border-slate-600/50 focus:border-green-600/60 text-slate-300 rounded-lg outline-none transition-all duration-200 text-sm appearance-none">
              <option value="" disabled selected>Selecione...</option>
              <option value="consultoria">Consultoria técnica</option>
              <option value="desenvolvimento">Desenvolvimento de software</option>
              <option value="arquitetura">Arquitetura de solução</option>
              <option value="ia">IA aplicada ao negócio</option>
              <option value="produto">Parceria em produto</option>
              <option value="outro">Outro</option>
            </select>
          </div>
          <div>
            <label for="contact-message" class="block text-slate-300 text-sm font-medium mb-1.5">Mensagem</label>
            <textarea id="contact-message" name="message" rows="4" placeholder="Descreva brevemente seu desafio ou projeto..."
                      class="w-full px-4 py-2.5 bg-slate-700/50 border border-slate-600/50 focus:border-green-600/60 text-white placeholder:text-slate-500 rounded-lg outline-none transition-all duration-200 text-sm resize-none"></textarea>
          </div>
          <button type="submit"
                  class="w-full py-3 bg-green-600 hover:bg-green-500 text-white font-semibold rounded-lg transition-all duration-200 shadow-lg shadow-green-900/30 flex items-center justify-center gap-2">
            Enviar mensagem
            <i data-lucide="send" class="w-4 h-4"></i>
          </button>
          <p class="text-slate-500 text-xs text-center">Respondemos em até 24h úteis.</p>
        </form>
      </div>

    </div>
  </div>
</section>